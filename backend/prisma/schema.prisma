generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  admin
  siswa
}

model User {
  id                Int         @id @default(autoincrement())
  fullname          String      @db.VarChar(100)
  username          String      @unique @db.VarChar(50)
  email             String      @unique @db.VarChar(100)
  password          String      @db.VarChar(255)
  role              Role        @default(siswa)
  verificationToken String?     @map("verification_token") @db.VarChar(255)
  isVerified        Boolean     @default(false) @map("is_verified")
  createdAt         DateTime    @default(now()) @map("created_at")
  orders            Order[]
  kelasSaya         KelasSaya[]
  reviews           Review[]

  @@map("users")
}

model KategoriKelas {
  id           Int     @id @default(autoincrement())
  namaKategori String  @map("nama_kategori") @db.VarChar(100)
  deskripsi    String? @db.Text
  kelas        Kelas[]

  @@map("kategori_kelas")
}

model Tutor {
  id         Int     @id @default(autoincrement())
  nama       String  @db.VarChar(100)
  email      String  @unique @db.VarChar(100)
  bio        String? @db.Text
  fotoProfil String? @map("foto_profil") @db.VarChar(255)
  kelas      Kelas[]

  @@map("tutors")
}

model Kelas {
  id         Int           @id @default(autoincrement())
  kategoriId Int           @map("kategori_id")
  tutorId    Int           @map("tutor_id")
  judul      String        @db.VarChar(200)
  deskripsi  String?       @db.Text
  harga      Decimal       @db.Decimal(10, 2)
  thumbnail  String?       @db.VarChar(255)
  createdAt  DateTime      @default(now()) @map("created_at")
  kategori   KategoriKelas @relation(fields: [kategoriId], references: [id])
  tutor      Tutor         @relation(fields: [tutorId], references: [id])
  modul      ModulKelas[]
  pretests   Pretest[]
  orders     Order[]
  kelasSaya  KelasSaya[]
  reviews    Review[]

  @@map("kelas")
}

model ModulKelas {
  id         Int        @id @default(autoincrement())
  kelasId    Int        @map("kelas_id")
  judulModul String     @map("judul_modul") @db.VarChar(150)
  urutan     Int
  kelas      Kelas      @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  materials  Material[]

  @@map("modul_kelas")
}

enum TipeMaterial {
  video
  rangkuman
  quiz
}

model Material {
  id            Int          @id @default(autoincrement())
  modulId       Int          @map("modul_id")
  tipe          TipeMaterial
  judulMaterial String       @map("judul_material") @db.VarChar(150)
  kontenUrl     String?      @map("konten_url") @db.VarChar(255)
  urutan        Int
  modul         ModulKelas   @relation(fields: [modulId], references: [id], onDelete: Cascade)

  @@map("materials")
}

model Pretest {
  id           Int     @id @default(autoincrement())
  kelasId      Int     @map("kelas_id")
  judulPretest String  @map("judul_pretest") @db.VarChar(150)
  deskripsi    String? @db.Text
  kelas        Kelas   @relation(fields: [kelasId], references: [id], onDelete: Cascade)

  @@map("pretests")
}

enum StatusOrder {
  pending
  sukses
  batal
}

model Order {
  id           Int         @id @default(autoincrement())
  userId       Int         @map("user_id")
  kelasId      Int         @map("kelas_id")
  statusOrder  StatusOrder @default(pending) @map("status_order")
  totalHarga   Decimal     @map("total_harga") @db.Decimal(10, 2)
  tanggalOrder DateTime    @default(now()) @map("tanggal_order")
  user         User        @relation(fields: [userId], references: [id])
  kelas        Kelas       @relation(fields: [kelasId], references: [id])
  pembayaran   Pembayaran?

  @@map("orders")
}

enum StatusPembayaran {
  pending
  sukses
  gagal
}

model Pembayaran {
  id               Int              @id @default(autoincrement())
  orderId          Int              @unique @map("order_id")
  metodePembayaran String?          @map("metode_pembayaran") @db.VarChar(50)
  statusPembayaran StatusPembayaran @default(pending) @map("status_pembayaran")
  jumlahBayar      Decimal          @map("jumlah_bayar") @db.Decimal(10, 2)
  tanggalBayar     DateTime         @default(now()) @map("tanggal_bayar")
  order            Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("pembayaran")
}

model KelasSaya {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  kelasId      Int      @map("kelas_id")
  progress     Int      @default(0)
  tanggalAkses DateTime @default(now()) @map("tanggal_akses")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kelas        Kelas    @relation(fields: [kelasId], references: [id], onDelete: Cascade)

  @@map("kelas_saya")
}

model Review {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  kelasId       Int      @map("kelas_id")
  rating        Int
  komentar      String?  @db.Text
  tanggalReview DateTime @default(now()) @map("tanggal_review")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kelas         Kelas    @relation(fields: [kelasId], references: [id], onDelete: Cascade)

  @@map("reviews")
}
